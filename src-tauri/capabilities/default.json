{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for GAIA",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "shell:allow-execute",
    "shell:allow-open",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "notification:default",
    "notification:allow-notify",
    "dialog:default",
    "dialog:allow-message",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
